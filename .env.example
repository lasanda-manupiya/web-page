# Copy to .env.production on the server and fill in. Do NOT commit real secrets.

# Public site URL (canonical / OG / sitemap). Set to your real domain.
NEXT_PUBLIC_SITE_URL=https://platform.i-cost.co.uk
# Set to "true" only at launch to allow search-engine indexing.
NEXT_PUBLIC_INDEXABLE=false

# Contact form email (SMTP) — required for /api/contact to send.
SMTP_HOST=mail.i-cost.co.uk
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kevin@i-cost.co.uk
SMTP_PASS=
# Optional overrides (defaults shown):
# CONTACT_TO=kevin@i-cost.co.uk
# CONTACT_CC=connect@sustainzone.earth
# CONTACT_FROM=kevin@i-cost.co.uk
